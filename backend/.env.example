# Copy this to .env and fill in your values
# DO NOT commit .env to GitHub

NODE_ENV=production
PORT=3001

# Change this to a long random string before going live
# Generate one: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-key

# Your frontend domain
FRONTEND_URL=https://tprainventory.ypj.sch.id

# Path to SQLite — Railway volume mounted here
DB_PATH=/data/database.sqlite

# Default password for the first Manager account on fresh deploy
ADMIN_PASSWORD=YPJ2025

# SMTP (Gmail) — use an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=natalius_marani@ypj.sch.id
SMTP_PASS=your-gmail-app-password-here
